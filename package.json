{
  "name": "zotoshop-test-playwright",
  "version": "0.1.0",
  "description": "Tests E2E Playwright pour ZotoShop",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "test:chromium": "playwright test --project=chromium",
    "test:api": "playwright test api.spec",
    "test:debug": "playwright test --debug",
    "report": "playwright show-report",
    "codegen": "playwright codegen http://localhost:8000",
    "lint": "eslint tests/",
    "typecheck": "tsc --noEmit --ignoreDeprecations 6.0",
    "prepare": "husky"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "dotenv": "^17.4.2",
    "eslint": "^10.3.0",
    "husky": "^9.1.7",
    "playwright": "^1.59.1",
    "typescript": "^6.0.3"
  }
}
